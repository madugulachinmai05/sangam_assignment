STREAMLIT:
import streamlit as st
st.title("Factors of a Number")
num = st.number_input("Enter a number:", min_value=1, step=1)
if st.button("Find Factors"):
    factors = []
    for i in range(1, int(num) + 1):
        if num % i == 0:
            factors.append(i)

    st.write(f"Factors of {int(num)} are:")
    st.write(factors)
