STREAMLIT:
import streamlit as st

st.title("Number Sign Checker")

n = st.number_input("Enter a number:", step=1)

if st.button("Check"):
    if n > 0:
        st.success("It is a Positive number.")
    elif n == 0:
        st.info("It is Zero.")
    else:
        st.error("It is a Negative number.")
