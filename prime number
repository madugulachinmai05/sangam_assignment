num = int(input("Enter a number: "))

if num <= 1:
    print("Not a prime number")
else:
    is_prime = True
    for i in range(2, num):
        if num % i == 0:
            is_prime = False
            break

    if is_prime:
        print("Prime number")
    else:
        print("Not a prime number")

STREAMLIT:
import streamlit as st
st.title("Prime Number Checker")
num = st.number_input("Enter a number:", step=1)
if st.button("Check Prime"):
    if num <= 1:
        st.error("Not a prime number.")
    else:
        is_prime = True
        for i in range(2, int(num)):
            if num % i == 0:
                is_prime = False
                break

        if is_prime:
            st.success("It is a Prime number.")
        else:
            st.error("It is not a Prime number.")
