STREAMLIT:
import streamlit as st

st.title("Arithmetic Operations Calculator")

num1 = st.number_input("Enter first number:", step=1)
num2 = st.number_input("Enter second number:", step=1)

if st.button("Calculate"):
    st.write("Addition:", num1 + num2)
    st.write("Subtraction:", num1 - num2)
    st.write("Multiplication:", num1 * num2)

    if num2 != 0:
        st.write("Division:", num1 / num2)
    else:
        st.warning("Division not possible (cannot divide by zero).")
