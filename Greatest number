BASIC CODE:
num1 = int(input("Enter first number: "))
num2 = int(input("Enter second number: "))

if num1 > num2:
    print("First number is greater")
elif num2 > num1:
    print("Second number is greater")
else:
    print("Both numbers are equal")

STREAMLIT:
import streamlit as st

st.title("Greatest of Two Numbers")

num1 = st.number_input("Enter first number:", step=1)
num2 = st.number_input("Enter second number:", step=1)

if st.button("Compare Numbers"):
    if num1 > num2:
        st.success("First number is greater.")
    elif num2 > num1:
        st.success("Second number is greater.")
    else:
        st.info("Both numbers are equal.")
